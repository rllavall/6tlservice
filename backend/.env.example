# Plantilla de configuración del backend 6TL Postventa.
# Copia este fichero a `.env` y rellena los valores. `.env` está en .gitignore.
# El backend carga `.env` al arrancar (app/env_file.py); el entorno real
# (Docker/systemd) siempre tiene prioridad sobre este fichero.

# --- Notificaciones: Telegram ---
# Crea el bot con @BotFather (/newbot) y obtén el token.
# El chat_id se obtiene escribiendo al bot y leyendo
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notificaciones: Email SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=support@6tlengineering.com
NOTIF_EMAIL_TO=support@6tlengineering.com

# --- Auth ---
# Días de validez de la sesión (token Bearer).
AUTH_SESION_DIAS=7
